name = "zenk-nav-config"
main = "index.mjs"
compatibility_date = "2026-05-07"
workers_dev = true

[[kv_namespaces]]
binding = "NAV_CONFIG_KV"
id = "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"

[vars]
ALLOWED_ORIGIN = "*"
GITHUB_REPO_OWNER = "ZenkAgent"
GITHUB_REPO_NAME = "ZenK"
GITHUB_REPO_BRANCH = "main"
GITHUB_CONFIG_PATH = "nav-config.json"
GITHUB_COMMIT_MESSAGE = "Sync nav-config.json from nav worker"
